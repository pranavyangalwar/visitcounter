{
    "name": "pranavsy/visitcounter",
    "description": "A Livewire visit counter component package",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Pranav Sy",
            "email": "your-email@example.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "Pranavsy\\VisitCounter\\": "src/"
        }
    },
    "require": {
        "php": "^8.0",
        "illuminate/support": "^9.0|^10.0",
        "livewire/livewire": "^2.0"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Pranavsy\\VisitCounter\\VisitCounterServiceProvider"
            ]
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "@php artisan vendor:publish --provider=\"Pranavsy\\VisitCounter\\VisitCounterServiceProvider\" --tag=config --force",
            "@php artisan vendor:publish --provider=\"Pranavsy\\VisitCounter\\VisitCounterServiceProvider\" --tag=views --force",
            "@php artisan vendor:publish --provider=\"Pranavsy\\VisitCounter\\VisitCounterServiceProvider\" --tag=migrations --force",
            "@php artisan migrate --force"
        ]
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}